# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your email address (required by NCBI for PubMed access)
ENTREZ_EMAIL=your.email@example.com

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
# NCBI API key — increases rate limit from 3 to 10 requests/sec
# Sign up free at: https://www.ncbi.nlm.nih.gov/account/
ENTREZ_API_KEY=

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use — must be pulled first with: ollama pull <model>
# Good options: llama3.2, mistral, gemma3, phi3, deepseek-r1
OLLAMA_MODEL=llama3.2

# Number of papers to fetch per disease query (default: 20)
MAX_PAPERS=20

# Number of top gene candidates to return (default: 10)
MAX_GENES=10
